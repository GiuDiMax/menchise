---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Ortodonzia - Centro Dentale Menchise" 
  description="Trattamenti ortodontici per adulti e bambini: apparecchi fissi, mobili e ortodonzia invisibile."
  bodyClass="bg-background text-foreground"
>
  <section class="w-full bg-secondary/20 py-20 px-4 text-center">
    <div class="max-w-4xl mx-auto space-y-6">
      <h1 class="text-4xl md:text-5xl font-extrabold text-primary">Ortodonzia</h1>
      <div class="w-24 h-1 bg-primary mx-auto rounded-full"></div>
    </div>
  </section>

  <article class="max-w-4xl mx-auto py-16 px-4 space-y-12">
    <div class="rounded-2xl overflow-hidden shadow-xl border border-border/50 my-8 max-w-lg mx-auto">
      <img src="/images/telegram/telegram-26.webp" alt="Ortodonzia" class="w-full h-auto object-cover" />
    </div>

    <div class="space-y-6 text-lg text-muted-foreground leading-relaxed">
      <ul class="list-disc list-inside space-y-4 marker:text-primary">
        <li>Ortodonzia intercettiva</li>
        <li>Ortodonzia mobile</li>
        <li>Ortodonzia fissa</li>
        <li>Ortodonzia invisibile</li>
        <li>Bite finale di contenzione</li>
        <li>Bite gnatologico</li>
        <li>Bite per bruxismo</li>
      </ul>
    </div>
  </article>
</Layout>
