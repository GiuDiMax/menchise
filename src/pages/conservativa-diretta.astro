---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Conservativa Diretta - Centro Dentale Menchise" 
  description="Ricostruzioni estetiche in composito per ripristinare la salute e l'estetica dei tuoi denti."
  bodyClass="bg-background text-foreground"
>
  <section class="w-full bg-secondary/20 py-20 px-4 text-center">
    <div class="max-w-4xl mx-auto space-y-6">
      <h1 class="text-4xl md:text-5xl font-extrabold text-primary">Conservativa Diretta</h1>
      <div class="w-24 h-1 bg-primary mx-auto rounded-full"></div>
    </div>
  </section>

  <article class="max-w-4xl mx-auto py-16 px-4 space-y-12">
    <div class="rounded-2xl overflow-hidden shadow-xl border border-border/50 my-8 max-w-lg mx-auto">
      <img src="/images/work/work-4.webp" alt="Conservativa Diretta" class="w-full h-auto object-cover" />
    </div>

    <div class="space-y-6 text-lg text-muted-foreground leading-relaxed">
      <ul class="list-disc list-inside space-y-4 marker:text-primary">
        <li>Ricostruzione estetica in composito</li>
        <li>Ricostruzione estetica elementi frontali</li>
        <li>Ricostruzione cervicale in composito</li>
        <li>Rilocazione margine in composito</li>
      </ul>
    </div>
  </article>
</Layout>
