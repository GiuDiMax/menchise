---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Terapia Canalare - Centro Dentale Menchise" 
  description="Trattamenti endodontici e devitalizzazioni per salvare i tuoi denti naturali."
  bodyClass="bg-background text-foreground"
>
  <section class="w-full bg-secondary/20 py-20 px-4 text-center">
    <div class="max-w-4xl mx-auto space-y-6">
      <h1 class="text-4xl md:text-5xl font-extrabold text-primary">Terapia Canalare o Devitalizzazioni</h1>
      <div class="w-24 h-1 bg-primary mx-auto rounded-full"></div>
    </div>
  </section>

  <article class="max-w-4xl mx-auto py-16 px-4 space-y-12">
    <div class="rounded-2xl overflow-hidden shadow-xl border border-border/50 my-8 max-w-lg mx-auto">
      <img src="/images/work/work-3.webp" alt="Terapia Canalare" class="w-full h-auto object-cover" />
    </div>

    <div class="space-y-6 text-lg text-muted-foreground leading-relaxed">
      <ul class="list-disc list-inside space-y-4 marker:text-primary">
        <li>Terapia canalare un canale (una radice)</li>
        <li>Terapia canalare due canali (due radici)</li>
        <li>Terapia canalare tre canali (tre radici)</li>
        <li>Ritrattamento terapia canalare un canale (una radice)</li>
        <li>Ritrattamento terapia canalare due canali (due radici)</li>
        <li>Ritrattamento terapia canalare tre canali (tre radici)</li>
        <li>Ritrattamento terapia canalare quattro canali (quattro radici)</li>
      </ul>
    </div>
  </article>
</Layout>
