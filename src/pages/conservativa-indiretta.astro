---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Conservativa Indiretta - Centro Dentale Menchise" 
  description="Intarsi in composito, disilicato di litio e ceramica per restauri durevoli ed estetici."
  bodyClass="bg-background text-foreground"
>
  <section class="w-full bg-secondary/20 py-20 px-4 text-center">
    <div class="max-w-4xl mx-auto space-y-6">
      <h1 class="text-4xl md:text-5xl font-extrabold text-primary">Conservativa Indiretta</h1>
      <div class="w-24 h-1 bg-primary mx-auto rounded-full"></div>
    </div>
  </section>

  <article class="max-w-4xl mx-auto py-16 px-4 space-y-12">
    <div class="rounded-2xl overflow-hidden shadow-xl border border-border/50 my-8 max-w-lg mx-auto">
      <img src="/images/telegram/telegram-31.webp" alt="Conservativa Indiretta" class="w-full h-auto object-cover" />
    </div>

    <div class="space-y-6 text-lg text-muted-foreground leading-relaxed">
      <ul class="list-disc list-inside space-y-4 marker:text-primary">
        <li>Intarsio in composito</li>
        <li>Intarsio in disilicato di litio</li>
        <li>Intarsio in ceramica</li>
        <li>Intarsio in oro (ormai in disuso)</li>
      </ul>
    </div>
  </article>
</Layout>
