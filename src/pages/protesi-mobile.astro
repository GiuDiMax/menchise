---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Protesi Mobile - Centro Dentale Menchise" 
  description="Protesi mobili parziali, totali e scheletrate per ripristinare funzionalità ed estetica."
  bodyClass="bg-background text-foreground"
>
  <section class="w-full bg-secondary/20 py-20 px-4 text-center">
    <div class="max-w-4xl mx-auto space-y-6">
      <h1 class="text-4xl md:text-5xl font-extrabold text-primary">Protesi Mobile</h1>
      <div class="w-24 h-1 bg-primary mx-auto rounded-full"></div>
    </div>
  </section>

  <article class="max-w-4xl mx-auto py-16 px-4 space-y-12">
    <div class="rounded-2xl overflow-hidden shadow-xl border border-border/50 my-8 max-w-lg mx-auto">
      <img src="/images/work/work-9.webp" alt="Protesi Mobile" class="w-full h-auto object-cover" />
    </div>

    <div class="space-y-6 text-lg text-muted-foreground leading-relaxed">
      <ul class="list-disc list-inside space-y-4 marker:text-primary">
        <li>Protesi mobile provvisoria resina e ganci</li>
        <li>Protesi mobile totale superiore o inferiore</li>
        <li>Protesi mobile parziale superiore o inferiore</li>
        <li>Protesi mobile scheletrata</li>
        <li>Ribasamento protesi mobile</li>
      </ul>
    </div>
  </article>
</Layout>
