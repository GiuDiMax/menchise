---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Protesi Fissa - Centro Dentale Menchise" 
  description="Soluzioni protesiche fisse: corone, faccette e riabilitazioni su impianti."
  bodyClass="bg-background text-foreground"
>
  <section class="w-full bg-secondary/20 py-20 px-4 text-center">
    <div class="max-w-4xl mx-auto space-y-6">
      <h1 class="text-4xl md:text-5xl font-extrabold text-primary">Protesi Fissa</h1>
      <div class="w-24 h-1 bg-primary mx-auto rounded-full"></div>
    </div>
  </section>

  <article class="max-w-4xl mx-auto py-16 px-4 space-y-12">
    <div class="rounded-2xl overflow-hidden shadow-xl border border-border/50 my-8 max-w-lg mx-auto">
      <img src="/images/work/work-4.webp" alt="Protesi Fissa" class="w-full h-auto object-cover" />
    </div>

    <div class="space-y-6 text-lg text-muted-foreground leading-relaxed">
      <ul class="list-disc list-inside space-y-4 marker:text-primary">
        <li>Elemento provvisorio in resina semplice</li>
        <li>Elemento provvisorio armato</li>
        <li>Elemento provvisorio su impianto</li>
        <li>Elemento in metallo/ceramica (anche su impianto osseo)</li>
        <li>Elemento in zirconio-ceramica (anche su impianto osseo)</li>
        <li>Elemento in disilicato di litio (anche su impianto osseo)</li>
        <li>Elemento in zirconio monolitico (anche su impianto osseo)</li>
        <li>Elemento in ceramica integrale (prevalentemente per la riabilitazione dei frontali)</li>
        <li>Faccetta in zirconio-ceramica (per i denti frontali)</li>
        <li>Faccetta in ceramica integrale (per i denti frontali)</li>
        <li>Riabilitazioni arcate su impianti (all-on-4 e all-on-6)</li>
        <li>Toronto su impianti (all-on-4 e all-on-6)</li>
      </ul>
    </div>
  </article>
</Layout>
