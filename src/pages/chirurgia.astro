---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Chirurgia - Centro Dentale Menchise" 
  description="Interventi chirurgici sicuri: estrazioni, apicectomie, rigenerazione ossea e chirurgia implantare."
  bodyClass="bg-background text-foreground"
>
  <section class="w-full bg-secondary/20 py-20 px-4 text-center">
    <div class="max-w-4xl mx-auto space-y-6">
      <h1 class="text-4xl md:text-5xl font-extrabold text-primary">Chirurgia</h1>
      <div class="w-24 h-1 bg-primary mx-auto rounded-full"></div>
    </div>
  </section>

  <article class="max-w-4xl mx-auto py-16 px-4 space-y-12">
    <div class="rounded-2xl overflow-hidden shadow-xl border border-border/50 my-8 max-w-lg mx-auto">
      <img src="/images/work/work-2.webp" alt="Chirurgia" class="w-full h-auto object-cover" />
    </div>

    <div class="space-y-6 text-lg text-muted-foreground leading-relaxed">
      <ul class="list-disc list-inside space-y-4 marker:text-primary">
        <li>Avulsione elementi dentari</li>
        <li>Chirurgia parodontale</li>
        <li>Apicectomia</li>
        <li>Chirurgia implantare</li>
        <li>Chirurgia implantare all-on-four oppure all-on six (grandi riabilitazioni per bocche edentule)</li>
        <li>Chirurgia di rigenerazione ossea (rigenerazione ossea necessaria per il posizionamento di impianti ossei quando si è in assenza di osso)</li>
        <li>Altro</li>
      </ul>
    </div>
  </article>
</Layout>
